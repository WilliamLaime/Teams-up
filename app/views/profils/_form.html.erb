<%# Formulaire partagé pour modifier le profil %>
<%# La variable @profil est passée automatiquement par le controller %>

<%# multipart: true est obligatoire pour les formulaires avec upload de fichier %>
<%= form_with model: @profil, url: profil_path, method: :patch, class: "row g-3", multipart: true do |f| %>

  <%# Affiche les erreurs de validation si le formulaire est invalide %>
  <% if @profil.errors.any? %>
    <div class="col-12">
      <div class="alert alert-danger">
        <ul class="mb-0">
          <% @profil.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <%# Nom affiché %>
  <div class="col-md-6">
    <%= f.label :name, "Nom", class: "form-label" %>
    <%= f.text_field :name, class: "form-control", placeholder: "Ton prénom ou pseudo" %>
  </div>

  <%# Téléphone %>
  <div class="col-md-6">
    <%= f.label :phone, "Téléphone", class: "form-label" %>
    <%= f.text_field :phone, class: "form-control", placeholder: "06 00 00 00 00" %>
  </div>

  <%# Adresse %>
  <div class="col-12">
    <%= f.label :address, "Adresse", class: "form-label" %>
    <%= f.text_field :address, class: "form-control", placeholder: "Ton adresse" %>
  </div>

  <%# Description personnelle %>
  <div class="col-12">
    <%= f.label :description, "À propos de toi", class: "form-label" %>
    <%= f.text_area :description, class: "form-control", rows: 3, placeholder: "Parle de toi, de ton style de jeu..." %>
  </div>

  <%# Niveau et rôle préféré sur la même ligne %>
  <div class="col-md-6">
    <%= f.label :level, "Niveau", class: "form-label" %>
    <%= f.select :level, ["Débutant", "Intermédiaire", "Avancé"], { include_blank: "Choisir ton niveau" }, class: "form-select" %>
  </div>

  <div class="col-md-6">
    <%= f.label :role, "Rôle préféré", class: "form-label" %>
    <%= f.text_field :role, class: "form-control", placeholder: "Ex: Attaquant, Gardien..." %>
  </div>

  <%# Photo de profil %>
  <div class="col-12">
    <%= f.label :avatar, "Photo de profil", class: "form-label" %>

    <%# Aperçu de la photo actuelle si elle existe déjà %>
    <% if @profil.avatar.attached? %>
      <div class="mb-2">
        <%= image_tag @profil.avatar, class: "rounded-circle", style: "width:80px;height:80px;object-fit:cover;" %>
        <small class="text-muted ms-2">Photo actuelle</small>
      </div>
    <% end %>

    <%# Champ de sélection du fichier — accepte uniquement les images %>
    <%= f.file_field :avatar, class: "form-control", accept: "image/*", id: "avatar_input" %>
    <div class="form-text">JPG, PNG ou GIF. Max 5 Mo.</div>

    <%# Prévisualisation JS de la nouvelle image avant envoi %>
    <div id="avatar_preview" class="mt-2" style="display:none;">
      <img id="avatar_preview_img" alt="Aperçu de ta photo de profil" class="rounded-circle" style="width:80px;height:80px;object-fit:cover;">
      <small class="text-muted ms-2">Aperçu</small>
    </div>

    <script>
      // Affiche un aperçu de l'image sélectionnée avant l'upload
      document.getElementById('avatar_input').addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = function(event) {
          document.getElementById('avatar_preview_img').src = event.target.result;
          document.getElementById('avatar_preview').style.display = 'block';
        };
        reader.readAsDataURL(file);
      });
    </script>
  </div>

  <%# Bouton de soumission %>
  <div class="col-12">
    <%= f.submit "Sauvegarder", class: "btn btn-primary" %>
  </div>

<% end %>
