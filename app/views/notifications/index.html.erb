<%# Page listant toutes les notifications de l'utilisateur connecté %>

<div class="container my-4">
  <div class="row justify-content-center">
    <div class="col-md-8">

      <%# En-tête avec titre et bouton "tout marquer comme lu" %>
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="d-flex align-items-center gap-2">
          <i data-lucide="bell" style="width:24px;height:24px;"></i>
          Notifications
        </h2>
        <%# Affiche le bouton seulement s'il y a au moins une notification non lue %>
        <% if @notifications.any? { |n| !n.read? } %>
          <%= button_to "Tout marquer comme lu", mark_all_read_notifications_path,
              method: :patch,
              class: "btn btn-outline-secondary btn-sm d-flex align-items-center gap-1" do %>
            <i data-lucide="check-check" style="width:14px;height:14px;"></i> Tout lire
          <% end %>
        <% end %>
      </div>

      <% if @notifications.any? %>
        <div class="list-group">
          <% @notifications.each do |notif| %>
            <%# Chaque notification est cliquable : marque comme lue et redirige %>
            <%= button_to mark_read_notification_path(notif), method: :patch,
                class: "w-100 text-start border-0 p-0 list-group-item list-group-item-action",
                style: "background: #{notif.read? ? 'white' : '#f0f7ff'};" do %>
              <div class="d-flex align-items-start gap-3 p-3">

                <%# Icône selon statut lu/non lu %>
                <% if notif.read? %>
                  <i data-lucide="check-circle" style="width:20px;height:20px;flex-shrink:0;margin-top:2px;" class="text-muted"></i>
                <% else %>
                  <i data-lucide="bell-dot" style="width:20px;height:20px;flex-shrink:0;margin-top:2px;" class="text-primary"></i>
                <% end %>

                <%# Contenu de la notification %>
                <div class="flex-grow-1">
                  <div class="<%= notif.read? ? 'text-muted' : 'fw-semibold' %>">
                    <%= notif.message %>
                  </div>
                  <small class="text-muted">
                    <i data-lucide="clock" style="width:12px;height:12px;"></i>
                    <%= time_ago_in_words(notif.created_at) %>
                  </small>
                </div>

                <%# Indicateur visuel "non lue" %>
                <% unless notif.read? %>
                  <span class="badge bg-primary rounded-pill">Nouveau</span>
                <% end %>

              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <%# État vide %>
        <div class="text-center text-muted py-5">
          <i data-lucide="inbox" style="width:48px;height:48px;"></i>
          <p class="mt-3">Tu n'as aucune notification pour le moment.</p>
        </div>
      <% end %>

    </div>
  </div>
</div>
