<%# ── Admin : Messages de contact ───────────────────────────────────────── %>
<%# Liste tous les messages reçus via le formulaire /contact %>
<%# Accessible uniquement aux admins (protégé par Admin::BaseController) %>

<div style="background-color:#111111; min-height:100vh;">
<div class="container py-4">

  <%# ── En-tête ── %>
  <div class="d-flex align-items-center gap-2 mb-4">
    <i data-lucide="mail" style="width:22px; height:22px; color:#1EDD88;"></i>
    <h1 style="font-size:1.4rem; font-weight:700; margin:0; color:#fff;">
      Espace <span style="color:#1EDD88;">Admin</span>
    </h1>
  </div>

  <%# ── Navigation par onglets centrée — partial partagé ── %>
  <%= render "admin/shared/nav", active_tab: :formulaires %>

  <%# ── Flash notices (succès / erreur) ── %>
  <% if notice %>
    <div class="alert alert-success mb-3" style="background:rgba(30,221,136,0.1); border:1px solid rgba(30,221,136,0.3); color:#1EDD88;">
      <%= notice %>
    </div>
  <% end %>
  <% if alert %>
    <div class="alert alert-danger mb-3" style="background:rgba(220,53,69,0.1); border:1px solid rgba(220,53,69,0.3); color:#ff6b6b;">
      <%= alert %>
    </div>
  <% end %>

  <%# ── Tableau des messages ── %>
  <div class="match-block">

    <%# Bouton "Tout supprimer" — visible uniquement s'il y a des messages %>
    <% if @contact_messages.any? %>
      <div class="d-flex justify-content-end mb-2">
        <%= button_to destroy_all_admin_contact_messages_path,
                      method: :delete,
                      class: "btn btn-sm",
                      style: "font-size:0.75rem; background:rgba(220,53,69,0.12); color:#ff6b6b; border:1px solid rgba(220,53,69,0.3);",
                      data: { turbo_confirm: "Supprimer tous les messages définitivement ? Cette action est irréversible." } do %>
          <i data-lucide="trash-2" style="width:12px; height:12px; margin-right:4px;"></i>
          Tout supprimer
        <% end %>
      </div>
    <% end %>

    <%# Tableau toujours présent dans le DOM pour recevoir les broadcasts Turbo Stream,
        même quand il n'y a aucun message au chargement de la page %>
    <table class="table table-dark table-hover mb-0" style="font-size:0.85rem;">
      <thead>
        <tr style="color:rgba(255,255,255,0.4); font-size:0.72rem; text-transform:uppercase; letter-spacing:0.05em;">
          <th style="border-color:rgba(255,255,255,0.07);">Statut</th>
          <th style="border-color:rgba(255,255,255,0.07);">Expéditeur</th>
          <th style="border-color:rgba(255,255,255,0.07);">Email</th>
          <th style="border-color:rgba(255,255,255,0.07);">Sujet</th>
          <th style="border-color:rgba(255,255,255,0.07);">Reçu le</th>
          <th style="border-color:rgba(255,255,255,0.07);">Actions</th>
        </tr>
      </thead>
      <%# id="contact_messages_tbody" — ciblé par broadcast_prepend_to pour insérer les nouvelles lignes %>
      <tbody id="contact_messages_tbody">
        <% if @contact_messages.any? %>
          <% @contact_messages.each do |msg| %>
            <%= render "admin/contact_messages/contact_message", msg: msg %>
          <% end %>
        <% else %>
          <%# Ligne "état vide" avec un id — supprimée automatiquement par broadcast_remove_to
              dès que le premier message arrive en temps réel via Turbo Stream %>
          <tr id="contact_messages_empty">
            <td colspan="6" class="text-center py-5" style="border:none;">
              <i data-lucide="inbox" style="width:40px; height:40px; color:rgba(255,255,255,0.2); margin-bottom:1rem; display:block; margin-left:auto; margin-right:auto;"></i>
              <p style="color:rgba(255,255,255,0.3); margin:0;">Aucun message de contact pour le moment.</p>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

  </div>

</div>
<%# / container %>
</div>
<%# / fond pleine largeur %>

<%# ════════════════════════════════════════════════════════════════════════════ %>
<%# MODALES — rendues en dehors du tableau pour éviter les problèmes de z-index %>
<%# id="contact_messages_modals" — ciblé par Turbo Stream pour ajouter les nouvelles modales %>
<%# ════════════════════════════════════════════════════════════════════════════ %>
<div id="contact_messages_modals">
  <% @contact_messages.each do |msg| %>
    <%= render "admin/contact_messages/contact_message_modal", msg: msg %>
  <% end %>
</div>
